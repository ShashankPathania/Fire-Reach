# ============================================================
# 🔥 FireReach AI – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Signal Ingestion ───────────────────────────────────────
SERPER_API_KEY=your_serper_api_key_here
# Get free key at: https://serper.dev

# ── Contact Discovery (Hunter) ─────────────────────────────
HUNTER_API_KEY=your_hunter_api_key_here
# Get key at: https://hunter.io
# If empty, FireReach falls back to search-based discovery.

# ── LLM Providers ─────────────────────────────────────────
LLM_PROVIDER=groq          # groq | gemini | openai
LLM_API_KEY=your_groq_api_key_here
# Groq free key: https://console.groq.com
# Groq model to use (override if needed):
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama fallback (local, no key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# ── Email (SendGrid primary → SMTP fallback) ──────────────
EMAIL_METHOD=sendgrid      # sendgrid | smtp

# SendGrid (primary)
SENDGRID_API_KEY=SG.your_sendgrid_key_here
# Get free key: https://sendgrid.com (100 emails/day free)

# SMTP fallback (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
# Gmail App Password: https://support.google.com/accounts/answer/185833

# Sender info (used by both methods)
FROM_EMAIL=your_email@gmail.com
FROM_NAME=FireReach AI

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./firereach.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/firereach

# ── Server ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PORT=8000
HOST=0.0.0.0

# ── Authentication ──────────────────────────────────────────
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Scoring Thresholds ────────────────────────────────────
SCORE_THRESHOLD=0.5        # Below this = skip outreach
DEDUP_DAYS=30              # Don't re-outreach within N days
